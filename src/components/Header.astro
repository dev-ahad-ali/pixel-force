---
import { Pilcrow } from "@lucide/astro";

const navLinks = [
    { name: "Home", href: "#home" },
    { name: "Services", href: "#services" },
    { name: "Projects", href: "#projects" },
    { name: "Technologies", href: "#technologies" },
    { name: "Testimonials", href: "#testimonials" },
    { name: "Blogs", href: "#blogs" },
];
---

<header
    id="site-header"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
    <div class="px-5 py-4">
        <div class="container mx-auto flex items-center justify-between">
            <!-- Logo -->
            <a
                href="/"
                class="flex items-center gap-2 no-underline"
                id="header-logo"
            >
                <div
                    class="w-10 h-10 bg-linear-to-br from-primary to-accent rounded-lg flex items-center justify-center shadow-sm"
                >
                    <Pilcrow class="text-xl font-bold" />
                </div>
                <span class="text-xl font-semibold text-base-content"
                    >Pixel Force</span
                >
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-8">
                {
                    navLinks.map((link) => (
                        <button
                            data-href={link.href}
                            class="nav-link btn btn-ghost btn-sm text-base text-base-content/80 hover:text-primary font-normal"
                        >
                            {link.name}
                        </button>
                    ))
                }
            </nav>

            <!-- Right Side Actions -->
            <div class="flex items-center gap-2">
                <!-- Theme Toggle -->
                <button
                    id="theme-toggle"
                    class="btn btn-ghost btn-square"
                    aria-label="Toggle theme"
                >
                    <!-- Sun icon (shown in dark mode) -->
                    <svg
                        id="icon-sun"
                        xmlns="http://www.w3.org/2000/svg"
                        class="hidden w-5 h-5 text-primary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
                        ></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                    <!-- Moon icon (shown in light mode) -->
                    <svg
                        id="icon-moon"
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5 text-primary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                        ></path>
                    </svg>
                </button>

                <!-- CTA Button — Desktop -->
                <button
                    data-href="#contact"
                    class="nav-link hidden lg:flex btn btn-primary text-base px-5 shadow-sm hover:shadow-primary/30 hover:shadow-md transition-shadow"
                >
                    Start a Project
                </button>

                <!-- Mobile Menu Toggle -->
                <label
                    for="mobile-drawer"
                    class="btn btn-ghost btn-sm btn-square lg:hidden"
                    aria-label="Toggle menu"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </label>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Drawer (DaisyUI drawer pattern, sidebar on the right) -->
<div class="drawer drawer-end lg:hidden">
    <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />

    <div class="drawer-side z-60">
        <label
            for="mobile-drawer"
            aria-label="close sidebar"
            class="drawer-overlay"></label>

        <div
            class="menu bg-base-100 min-h-full w-72 p-6 flex flex-col gap-2 shadow-xl"
        >
            <!-- Drawer Header -->
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <div
                        class="w-8 h-8 bg-linear-to-br from-primary to-accent rounded-lg flex items-center justify-center"
                    >
                        <Pilcrow class="text-sm font-bold" />
                    </div>
                    <span class="font-semibold text-base-content"
                        >Pixel Force</span
                    >
                </div>
                <label
                    for="mobile-drawer"
                    class="btn btn-ghost btn-sm btn-square"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </label>
            </div>

            <div class="divider my-0"></div>

            <!-- Nav Links -->
            {
                navLinks.map((link) => (
                    <label for="mobile-drawer">
                        <button
                            data-href={link.href}
                            class="nav-link btn btn-ghost btn-sm w-full justify-start text-base-content/80 hover:text-primary font-normal"
                        >
                            {link.name}
                        </button>
                    </label>
                ))
            }

            <div class="mt-auto pt-4">
                <label for="mobile-drawer">
                    <button
                        data-href="#contact"
                        class="nav-link btn btn-primary w-full"
                    >
                        Start a Project
                    </button>
                </label>
            </div>
        </div>
    </div>
</div>

<style>
    /* Scrolled state applied via JS */
    #site-header.scrolled {
        /*background-color: oklch(var(--b1) / 0.85);*/
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        /*border-bottom: 1px solid oklch(var(--b3));*/
        box-shadow: 0 1px 3px oklch(0 0 0 / 0.05);
    }

    /* Fade-in animation for header items */
    #site-header {
        animation: fadeInDown 0.4s ease both;
    }

    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // ── Scroll: add/remove .scrolled on header ────────────────────
    const header = document.getElementById("site-header");
    const onScroll = () => {
        header?.classList.toggle("scrolled", window.scrollY > 20);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll(); // run once on load

    // // ── Smooth scroll for all nav-link buttons ────────────────────
    document.querySelectorAll<HTMLButtonElement>(".nav-link").forEach((btn) => {
        btn.addEventListener("click", (e) => {
            const href = btn.dataset.href;
            if (!href) return;

            const isHomePage = window.location.pathname === "/";

            if (isHomePage) {
                const target = document.querySelector(href);
                target?.scrollIntoView({ behavior: "smooth" });
            } else {
                sessionStorage.setItem("scrollToSection", href);
                window.location.href = "/";
            }
        });
    });

    // Scroll to section after navigation to home
    window.addEventListener("load", () => {
        const sectionToScroll = sessionStorage.getItem("scrollToSection");
        if (sectionToScroll) {
            sessionStorage.removeItem("scrollToSection");
            setTimeout(() => {
                const target = document.querySelector(sectionToScroll);
                target?.scrollIntoView({ behavior: "smooth" });
            }, 100);
        }
    });

    // ── Theme toggle ──────────────────────────────────────────────
    const LIGHT = "emerald-light";
    const DARK = "emerald-dark";
    const html = document.documentElement;
    const sun = document.getElementById("icon-sun");
    const moon = document.getElementById("icon-moon");

    const applyTheme = (theme: string) => {
        html.dataset.theme = theme;
        localStorage.setItem("theme", theme);
        const isDark = theme === DARK;
        sun?.classList.toggle("hidden", !isDark);
        moon?.classList.toggle("hidden", isDark);
    };

    // Initialise from storage or OS preference
    const saved = localStorage.getItem("theme");
    const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
    ).matches;
    applyTheme(saved ?? (prefersDark ? DARK : LIGHT));

    document.getElementById("theme-toggle")?.addEventListener("click", () => {
        applyTheme(html.dataset.theme === DARK ? LIGHT : DARK);
    });
</script>
