---
const imageUrl =
    "https://images.unsplash.com/photo-1575388902449-6bca946ad549?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBkYXNoYm9hcmQlMjBpbnRlcmZhY2UlMjBkYXJrfGVufDF8fHx8MTc3MzE5NTU0MHww&ixlib=rb-4.1.0&q=80&w=1080";

const stats = [
    { value: "100+", label: "Projects" },
    { value: "50+", label: "Clients" },
    { value: "5+", label: "Years" },
];
---

<section id="home" class="pt-32 pb-20 lg:pt-40 lg:pb-32 px-6 overflow-x-clip">
    <div class="container mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- ── Left Content ──────────────────────────────────── -->
            <div class="space-y-8 hero-left">
                <!-- Badge -->
                <div class="inline-block hero-badge">
                    <span
                        class="badge badge-soft badge-primary text-sm font-medium px-4 py-3 rounded-full"
                    >
                        ✨ Modern Digital Solutions
                    </span>
                </div>

                <!-- Headline -->
                <h1
                    class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight hero-heading"
                >
                    We Build Digital Experiences That{" "}
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent"
                    >
                        Grow Your Business
                    </span>
                </h1>

                <!-- Body copy -->
                <p
                    class="text-lg text-base-content/60 leading-relaxed max-w-xl hero-body"
                >
                    Transform your vision into reality with our expert team. We
                    deliver exceptional digital marketing, cutting-edge
                    websites, memorable branding, and powerful AI automation
                    solutions that drive real results.
                </p>

                <!-- CTAs -->
                <div class="flex flex-col sm:flex-row gap-4 pt-4 hero-ctas">
                    <button
                        id="cta-get-started"
                        class="btn btn-primary btn-lg gap-2 group shadow-lg hover:shadow-primary/30 hover:shadow-xl transition-shadow"
                    >
                        Get Started
                        <!-- Arrow icon -->
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 transition-transform group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </button>

                    <button
                        id="cta-view-work"
                        class="btn btn-outline btn-lg gap-2 hover:btn-primary group border-2 transition-all"
                    >
                        <!-- Play icon -->
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 text-primary group-hover:text-primary-content transition-colors"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path d="M8 5v14l11-7z"></path>
                        </svg>
                        View Our Work
                    </button>
                </div>

                <!-- Stats -->
                <div
                    class="grid grid-cols-3 gap-6 pt-8 border-t border-base-300 hero-stats"
                >
                    {
                        stats.map(({ value, label }) => (
                            <div>
                                <div class="text-3xl font-bold text-primary">
                                    {value}
                                </div>
                                <div class="text-sm text-base-content/60 mt-1">
                                    {label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- ── Right Visual ──────────────────────────────────── -->
            <div class="relative hero-right">
                <!-- Glow blob behind image -->
                <div
                    class="pointer-events-none absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-primary/5 blur-3xl"
                >
                </div>

                <!-- Main image -->
                <div class="relative rounded-2xl overflow-hidden shadow-2xl">
                    <img
                        src={imageUrl}
                        alt="Modern Dashboard Interface"
                        class="w-full h-auto block"
                        loading="eager"
                        onerror="this.src='https://placehold.co/1080x720/1a1a1a/10b981?text=DigitalCraft'"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-base-100/20 to-transparent pointer-events-none"
                    >
                    </div>
                </div>

                <!-- Floating card — bottom-left -->
                <div
                    class="float-card float-card-bottom absolute -bottom-6 -left-6 hidden lg:block"
                >
                    <div
                        class="card bg-base-100/90 backdrop-blur-md border border-base-300 shadow-xl"
                    >
                        <div class="card-body p-4 flex-row items-center gap-3">
                            <div
                                class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0"
                            >
                                <span class="text-2xl">🚀</span>
                            </div>
                            <div>
                                <div class="font-semibold text-base-content">
                                    Fast Delivery
                                </div>
                                <div class="text-sm text-base-content/60">
                                    On-time results
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Floating card — top-right -->
                <div
                    class="float-card float-card-top absolute -top-6 -right-6 hidden lg:block"
                >
                    <div
                        class="card bg-base-100/90 backdrop-blur-md border border-base-300 shadow-xl"
                    >
                        <div class="card-body p-4 flex-row items-center gap-3">
                            <div
                                class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center shrink-0"
                            >
                                <span class="text-2xl">⭐</span>
                            </div>
                            <div>
                                <div class="font-semibold text-base-content">
                                    Top Quality
                                </div>
                                <div class="text-sm text-base-content/60">
                                    Premium work
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* ── Entrance animations ──────────────────────────────────── */
    .hero-left {
        animation: slideInLeft 0.6s ease both;
    }
    .hero-right {
        animation: slideInRight 0.6s ease 0.2s both;
    }

    .hero-badge {
        animation: scalePop 0.4s ease 0.2s both;
    }
    .hero-stats {
        animation: fadeInUp 0.5s ease 0.4s both;
    }

    .float-card-bottom {
        animation: fadeInUp 0.5s ease 0.6s both;
    }
    .float-card-top {
        animation: fadeInDown 0.5s ease 0.8s both;
    }

    @keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    @keyframes scalePop {
        from {
            opacity: 0;
            transform: scale(0.8);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Button press feedback */
    #cta-get-started:active,
    #cta-view-work:active {
        transform: scale(0.96);
    }
</style>

<script>
    const scrollTo = (selector: string) =>
        document
            .querySelector(selector)
            ?.scrollIntoView({ behavior: "smooth" });

    document
        .getElementById("cta-get-started")
        ?.addEventListener("click", () => scrollTo("#contact"));
    document
        .getElementById("cta-view-work")
        ?.addEventListener("click", () => scrollTo("#projects"));
</script>
