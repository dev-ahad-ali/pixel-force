---
const currentYear = new Date().getFullYear();

const navLinks = [
    { name: "Home", href: "#home" },
    { name: "Services", href: "#services" },
    { name: "Projects", href: "#projects" },
    { name: "Technologies", href: "#technologies" },
    { name: "Testimonials", href: "#testimonials" },
];

const services = [
    "Digital Marketing",
    "Website Development",
    "Logo & Brand Design",
    "AI Automation",
    "SEO Optimization",
];

const socials = [
    {
        label: "Facebook",
        href: "#",
        svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
    },
    {
        label: "Twitter / X",
        href: "#",
        svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    },
    {
        label: "LinkedIn",
        href: "#",
        svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>`,
    },
    {
        label: "Instagram",
        href: "#",
        svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
    },
];

const legalLinks = [
    { name: "Privacy Policy", href: "/legal/privacy-policy" },
    { name: "Terms of Service", href: "/legal/terms-of-service" },
    { name: "Cookie Policy", href: "/legal/cookie-policy" },
];
---

<footer class="bg-base-200/50 border-t border-base-300">
    <div class="px-5 py-16">
        <div
            class="container mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12"
        >
            <!-- Column 1: Company Info -->
            <div>
                <div class="flex items-center gap-2 mb-4">
                    <div
                        class="w-10 h-10 bg-linear-to-br from-primary to-accent rounded-lg flex items-center justify-center shadow-sm"
                    >
                        <span class="text-primary-content text-xl font-bold"
                            >P</span
                        >
                    </div>
                    <span class="text-xl font-semibold text-base-content"
                        >Pixel Force</span
                    >
                </div>

                <p class="text-base-content/60 text-sm leading-relaxed mb-6">
                    We create exceptional digital experiences that help
                    businesses grow and thrive in the modern digital landscape.
                </p>

                <!-- Social icons -->
                <div class="flex gap-3">
                    {
                        socials.map((social) => (
                            <a
                                href={social.href}
                                aria-label={social.label}
                                class="w-10 h-10 bg-primary/10 hover:bg-primary hover:text-primary-content text-base-content
                     rounded-lg flex items-center justify-center transition-all duration-200"
                                set:html={social.svg}
                            />
                        ))
                    }
                </div>
            </div>

            <!-- Column 2: Quick Links -->
            <div>
                <h4 class="font-semibold mb-4 text-base-content">
                    Quick Links
                </h4>
                <ul class="space-y-3">
                    {
                        navLinks.map((link) => (
                            <li>
                                <button
                                    data-href={link.href}
                                    class="footer-nav-btn text-base-content/60 hover:text-primary transition-colors text-sm cursor-pointer"
                                >
                                    {link.name}
                                </button>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Column 3: Services -->
            <div>
                <h4 class="font-semibold mb-4 text-base-content">Services</h4>
                <ul class="space-y-3">
                    {
                        services.map((service) => (
                            <li>
                                <a
                                    href="#services"
                                    class="text-base-content/60 hover:text-primary transition-colors text-sm"
                                >
                                    {service}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div>
                <h4 class="font-semibold mb-4 text-base-content">Contact Us</h4>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <!-- Mail icon -->
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 text-primary mt-0.5 shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <a
                            href="mailto:hello@digitalcraft.com"
                            class="text-base-content/60 hover:text-primary transition-colors text-sm"
                        >
                            hello@digitalcraft.com
                        </a>
                    </li>

                    <li class="flex items-start gap-3">
                        <!-- Phone icon -->
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 text-primary mt-0.5 shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <a
                            href="tel:+1234567890"
                            class="text-base-content/60 hover:text-primary transition-colors text-sm"
                        >
                            +1 (234) 567-890
                        </a>
                    </li>

                    <li class="flex items-start gap-3">
                        <!-- MapPin icon -->
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 text-primary mt-0.5 shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span class="text-base-content/60 text-sm">
                            123 Business Street<br />
                            San Francisco, CA 94102
                        </span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div
            class="pt-8 border-t border-base-300 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p class="text-base-content/60 text-sm">
                © {currentYear} Pixel Force. All rights reserved.
            </p>
            <div class="flex gap-6">
                {
                    legalLinks.map((link) => (
                        <a
                            href={link.href}
                            class="text-base-content/60 hover:text-primary transition-colors text-sm"
                        >
                            {link.name}
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</footer>

<script>
    document
        .querySelectorAll<HTMLButtonElement>(".footer-nav-btn")
        .forEach((btn) => {
            btn.addEventListener("click", () => {
                const href = btn.dataset.href;
                if (!href) return;
                document
                    .querySelector(href)
                    ?.scrollIntoView({ behavior: "smooth" });
            });
        });
</script>
