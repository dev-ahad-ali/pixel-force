---
const categories = ["React.Js", "Next.Js", "Wordpress", "Astro"];
---

<section id="projects" class="py-20 lg:py-32 px-6">
    <div class="container mx-auto">
        <!-- Section Header -->
        <div class="text-center max-w-3xl mx-auto mb-16 observe-fade-up">
            <span
                class="badge badge-soft badge-primary text-sm font-medium px-4 py-3 rounded-full mb-4"
            >
                Our Work
            </span>
            <h2
                class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 mb-6 text-base-content"
            >
                Featured Projects
            </h2>
            <p class="text-lg text-base-content/60">
                Explore our portfolio of successful projects that delivered
                exceptional results
            </p>
        </div>

        <div class="join w-full justify-center mb-12">
            {
                categories.map((item, idx) => (
                    <button
                        class={`btn join-item ${idx === 0 ? "btn-primary" : ""}`}
                        data-category={item}
                    >
                        {item}
                    </button>
                ))
            }
        </div>

        <!-- Projects Grid -->
        <div class="grid md:grid-cols-3 gap-8"></div>
    </div>
</section>

<script>
    const btns = document.getElementsByClassName("btn");
    for (let btn of btns) {
        btn.addEventListener("click", () => {
            console.log(btn.getAttribute("data-category"));

            for (let btn of btns) {
                if (btn.classList.contains("btn-primary")) {
                    btn.classList.remove("btn-primary");
                }
            }

            btn.classList.add("btn-primary");
        });
    }
</script>
