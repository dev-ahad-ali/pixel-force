---
import { getCollection, type CollectionEntry } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import ProjectModal from "../components/ui/ProjectModal.astro";
import SectionHeader from "./ui/SectionHeader.astro";

type Project = CollectionEntry<"projects">;

const projects = await getCollection("projects");

const webDevelopmentProjects = projects.filter(
    (item: Project) => item.data.category === "Web Development",
);

const digitalMarketingProjects = projects.filter(
    (item: Project) => item.data.category === "Digital Marketing",
);

const designProjects = projects.filter(
    (item: Project) => item.data.category === "Logo & Brand Design",
);

const aiAutomationProjects = projects.filter(
    (item: Project) => item.data.category === "AI Automation",
);

const categories = [
    "Web Development",
    "Digital Marketing",
    "Logo & Brand Design",
    "AI Automation",
];
---

<section id="projects" class="py-20 lg:py-32 px-5">
    <div class="container mx-auto">
        <SectionHeader
            label="Our Work"
            title="Featured Projects"
            description="Explore our portfolio of successful projects that delivered exceptional results"
        />

        <div
            class="join w-full justify-center mb-12 tab-btns overflow-x-scroll md:overflow-x-hidden overflow-y-hidden"
        >
            {
                categories.map((item, idx) => (
                    <button
                        class={`project-tab-btn btn join-item ${idx === 0 ? "btn-primary project-tab-active" : ""}`}
                        data-category={item}
                    >
                        {item}
                    </button>
                ))
            }
        </div>

        <!-- Projects Grid -->
        <div
            id={categories[0]}
            class="hidden md:grid-cols-3 gap-8 project-grid"
        >
            {
                webDevelopmentProjects.map((project: Project, idx: number) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
        <div
            id={categories[1]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                digitalMarketingProjects.map(
                    (project: Project, idx: number) => (
                        <ProjectCard data={project} index={idx} />
                    ),
                )
            }
        </div>
        <div
            id={categories[2]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                designProjects.map((project: Project, idx: number) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
        <div
            id={categories[3]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                aiAutomationProjects.map((project: Project, idx: number) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
    </div>
    <ProjectModal />
</section>

<script>
    const btns = document.querySelectorAll(
        ".project-tab-btn",
    ) as NodeListOf<HTMLElement>;

    const contents = document.querySelectorAll(".project-grid");

    function showTabContent(activeCategory: string) {
        contents.forEach((content) => {
            const isActive = content.id === activeCategory;
            content.classList.toggle("hidden", !isActive);
            content.classList.toggle("grid", isActive);
        });
    }

    function checkHoverBg() {
        btns.forEach((b) => {
            if (
                b.classList.contains("btn-primary") &&
                b.classList.contains("project-tab-active")
            ) {
                b.classList.remove("hover:bg-primary/20");
            } else {
                b.classList.add("hover:bg-primary/20");
            }
        });
    }

    checkHoverBg();

    document.querySelector(".tab-btns")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement)?.closest(
            ".project-tab-btn",
        ) as HTMLElement | null;

        if (!btn) return;

        btns.forEach((b) => {
            b.classList.remove("btn-primary", "project-tab-active");
        });
        btn.classList.add("btn-primary", "project-tab-active");

        showTabContent(btn.dataset.category || "");

        checkHoverBg();
    });

    showTabContent(btns[0]?.dataset.category || "");
</script>
