---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
interface Project {
    title: string;
    overview: string;
    client: string;
    image: string;
    category: string;
    services: string[];
    technologies: string[];
    keyResults: {
        metric: string;
        value: string;
        description: string;
    }[];
    featured: boolean;
    publishedAt: Date;
}

const projects = await getCollection("projects");

const webDevelopmentProjects = projects.filter(
    (item) => item.data.category === "Web Development",
);

const digitalMarketingProjects = projects.filter(
    (item) => item.data.category === "Digital Marketing",
);

const designProjects = projects.filter(
    (item) => item.data.category === "Logo & Brand Design",
);

const aiAutomationProjects = projects.filter(
    (item) => item.data.category === "AI Automation",
);

const categories = [
    "Web Development",
    "Digital Marketing",
    "Logo & Brand Design",
    "AI Automation",
];
---

<section id="projects" class="py-20 lg:py-32 px-6">
    <div class="container mx-auto">
        <!-- Section Header -->
        <div class="text-center max-w-3xl mx-auto mb-16 observe-fade-up">
            <span
                class="badge badge-soft badge-primary text-sm font-medium px-4 py-3 rounded-full mb-4"
            >
                Our Work
            </span>
            <h2
                class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 mb-6 text-base-content"
            >
                Featured Projects
            </h2>
            <p class="text-lg text-base-content/60">
                Explore our portfolio of successful projects that delivered
                exceptional results
            </p>
        </div>

        <div class="join w-full justify-center mb-12 tab-btns">
            {
                categories.map((item, idx) => (
                    <button
                        class={`project-tab-btn btn join-item ${idx === 0 ? "btn-primary project-tab-active" : ""}`}
                        data-category={item}
                    >
                        {item}
                    </button>
                ))
            }
        </div>

        <!-- Projects Grid -->
        <div
            id={categories[0]}
            class="hidden md:grid-cols-3 gap-8 project-grid"
        >
            {
                webDevelopmentProjects.map((project, idx) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
        <div
            id={categories[1]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                digitalMarketingProjects.map((project, idx) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
        <div
            id={categories[2]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                designProjects.map((project, idx) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
        <div
            id={categories[3]}
            class="md:grid-cols-3 gap-8 hidden project-grid"
        >
            {
                aiAutomationProjects.map((project, idx) => (
                    <ProjectCard data={project} index={idx} />
                ))
            }
        </div>
    </div>
</section>

<script>
    const btns = document.querySelectorAll(
        ".project-tab-btn",
    ) as NodeListOf<HTMLElement>;

    const contents = document.querySelectorAll(".project-grid");

    function showTabContent(activeCategory: string) {
        contents.forEach((content) => {
            const isActive = content.id === activeCategory;
            content.classList.toggle("hidden", !isActive);
            content.classList.toggle("grid", isActive);
        });
    }

    document.querySelector(".tab-btns")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement)?.closest(
            ".project-tab-btn",
        ) as HTMLElement | null;

        if (!btn) return;

        btns.forEach((b) =>
            b.classList.remove("btn-primary", "project-tab-active"),
        );
        btn.classList.add("btn-primary", "project-tab-active");

        showTabContent(btn.dataset.category || "");
    });

    showTabContent(btns[0]?.dataset.category || "");
</script>
