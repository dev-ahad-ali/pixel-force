---
interface Props {
    post: {
        data: {
            title: string;
            excerpt: string;
            slug: string;
            author: string;
            authorRole: string;
            authorImage: string;
            coverImage: string;
            category: string;
            tags: string[];
            readingTime: number;
            publishedAt: Date;
            featured: boolean;
        };
    };
    index: number;
}

const { post, index } = Astro.props;
const { data } = post;

const formattedDate = new Date(data.publishedAt).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<a
    href={`/blog/${data.slug}`}
    class="observe-fade-up group cursor-pointer block"
    style={`--delay: ${index * 100}ms`}
>
    <div
        class="card-inner relative overflow-hidden rounded-2xl bg-base-100 border border-base-300 hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5 h-full"
    >
        <!-- Cover image -->
        <figure class="relative aspect-video overflow-hidden">
            <img
                src={data.coverImage}
                alt={data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
                onerror={`this.src='https://placehold.co/800x450/1a1a1a/10b981?text=' + encodeURIComponent('${data.title}')`}
            />
            <!-- Gradient overlay -->
            <div
                class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
            >
            </div>
            <!-- Category badge -->
            <div class="absolute top-4 right-4">
                <span class="badge badge-primary text-white text-sm">
                    {data.category}
                </span>
            </div>
            <!-- Reading time badge -->
            <div class="absolute top-4 left-4">
                <span
                    class="badge badge-ghost bg-black/50 text-white border-0 text-xs backdrop-blur-sm"
                >
                    {data.readingTime} min read
                </span>
            </div>
        </figure>

        <!-- Content -->
        <div class="p-6 flex flex-col gap-3">
            <!-- Tags -->
            <div class="flex flex-wrap gap-1">
                {
                    data.tags
                        .slice(0, 2)
                        .map((tag) => (
                            <span class="text-xs text-primary/70 font-medium">
                                #{tag}
                            </span>
                        ))
                }
            </div>

            <!-- Title -->
            <h3
                class="text-lg font-semibold leading-snug transition-colors duration-200 group-hover:text-primary text-base-content line-clamp-2"
            >
                {data.title}
            </h3>

            <!-- Excerpt -->
            <p
                class="text-base-content/60 text-sm leading-relaxed line-clamp-2"
            >
                {data.excerpt}
            </p>

            <!-- Author + date row -->
            <div
                class="flex items-center gap-3 pt-2 mt-auto border-t border-base-300"
            >
                <img
                    src={data.authorImage}
                    alt={data.author}
                    class="w-8 h-8 rounded-full object-cover bg-base-300"
                    onerror="this.src='https://placehold.co/32x32/1a1a1a/10b981?text=A'"
                />
                <div class="flex flex-col min-w-0">
                    <span class="text-sm font-medium text-base-content truncate"
                        >{data.author}</span
                    >
                    <span class="text-xs text-base-content/50"
                        >{formattedDate}</span
                    >
                </div>
                <!-- Arrow icon -->
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 ml-auto text-base-content/30 group-hover:text-primary group-hover:translate-x-1 transition-all duration-200"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </div>
        </div>
    </div>
</a>

<style>
    .card-inner {
        transform: translateY(0);
        transition:
            transform 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    a:hover .card-inner {
        transform: translateY(-8px);
    }

    .observe-fade-up {
        opacity: 0;
        transform: translateY(24px);
        transition:
            opacity 0.55s ease calc(var(--delay, 0ms)),
            transform 0.55s ease calc(var(--delay, 0ms));
    }

    .observe-fade-up.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) =>
            entries.forEach((e) => {
                if (e.isIntersecting) {
                    e.target.classList.add("in-view");
                    observer.unobserve(e.target);
                }
            }),
        { threshold: 0.12 },
    );

    document
        .querySelectorAll(".observe-fade-up")
        .forEach((el) => observer.observe(el));
</script>
