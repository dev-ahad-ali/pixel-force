---
import { render } from "astro:content";

interface KeyResult {
    metric: string;
    value: string;
    description: string;
}

interface Project {
    title: string;
    overview: string;
    client: string;
    image: string;
    thumbnail: string;
    category: string;
    services: string[];
    technologies: string[];
    keyResults: KeyResult[];
    featured: boolean;
    publishedAt: Date;
}

const { data, index } = Astro.props;
const project = data.data;

// Render markdown body to HTML at build time
const { Content } = await render(data);

// Serialize only frontmatter for the modal script
const projectJson = JSON.stringify(project);
---

<div
    class="observe-fade-up group cursor-pointer project-card px-0.5"
    style={`--delay: ${index * 100}ms`}
    data-project={projectJson}
>
    <!--
        Hidden <template> tag: Astro renders <Content /> to real HTML here at
        build time. The modal script reads .innerHTML at click time and injects
        it — no client-side markdown parsing needed.
    -->
    <template class="project-case-study">
        <Content />
    </template>

    <div
        class="card-inner relative overflow-hidden rounded-2xl bg-base-100 border border-neutral/20 hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5"
    >
        <figure class="relative aspect-4/3 overflow-hidden">
            <img
                src={project.thumbnail}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 rounded-t-2xl"
                loading="lazy"
                onerror={`this.src='https://placehold.co/800x600/1a1a1a/10b981?text=' + encodeURIComponent('${project.title}')`}
            />
            <div
                class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
            >
            </div>
            <div class="absolute top-4 right-4">
                <span class="badge badge-primary text-white text-sm"
                    >{project.category}</span
                >
            </div>
        </figure>

        <div class="p-6">
            <h3
                class="text-xl font-semibold mb-2 transition-colors duration-200 group-hover:text-primary text-base-content"
            >
                {project.title}
            </h3>
            <p class="text-base-content/60 text-sm">
                {project.overview.substring(0, 100)}...
            </p>
        </div>
    </div>
</div>

<style>
    .card-inner {
        transform: translateY(0);
        transition:
            transform 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }
    .project-card:hover .card-inner {
        transform: translateY(-8px);
    }

    .observe-fade-up {
        opacity: 0;
        transform: translateY(24px);
        transition:
            opacity 0.55s ease calc(var(--delay, 0ms)),
            transform 0.55s ease calc(var(--delay, 0ms));
    }
    .observe-fade-up.in-view {
        opacity: 1;
        transform: translateY(0);
    }
</style>
