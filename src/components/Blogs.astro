---
import { getCollection, type CollectionEntry } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import SectionHeader from "./ui/SectionHeader.astro";

type BlogPost = CollectionEntry<"blog">;

const posts = await getCollection("blog");
const sorted = posts
    .sort(
        (a: BlogPost, b: BlogPost) =>
            b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
    )
    .slice(0, 4);
---

<section id="blogs" class="py-20 lg:py-32 px-5 bg-base-200/50">
    <SectionHeader
        label="Blogs"
        title="Leatest Updates"
        description="Read the latest new ideas from us on growing a bussiness."
    />

    <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 container mx-auto"
    >
        {
            sorted.map((post: BlogPost, i: number) => (
                <BlogCard post={post} index={i} />
            ))
        }
    </div>
</section>
