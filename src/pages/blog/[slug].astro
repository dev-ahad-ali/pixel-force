---
// src/pages/blog/[slug].astro
import { render, type CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

// ── Type derived directly from the blog collection ────────────────────────────
type BlogPost = CollectionEntry<"blog">;

interface Props {
    post: BlogPost;
    allPosts: BlogPost[];
    prevPost: BlogPost | null;
    nextPost: BlogPost | null;
}
// ─────────────────────────────────────────────────────────────────────────────

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const sorted = allPosts.sort(
        (a: BlogPost, b: BlogPost) =>
            b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
    );

    return sorted.map((post: BlogPost, index: number) => ({
        params: { slug: post.data.slug },
        props: {
            post,
            allPosts: sorted,
            prevPost: index < sorted.length - 1 ? sorted[index + 1] : null,
            nextPost: index > 0 ? sorted[index - 1] : null,
        } satisfies Props,
    }));
}

const { post, allPosts, prevPost, nextPost }: Props = Astro.props;

const categoryPosts: BlogPost[] = allPosts
    .filter(
        (item: BlogPost) =>
            item.data.category === post.data.category &&
            item.data.slug !== post.data.slug,
    )
    .slice(0, 4);

const { data } = post;
const { Content } = await render(post);

const formattedDate = new Date(data.publishedAt).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

// Helper so prev/next date formatting is DRY
const shortDate = (d: Date): string =>
    new Date(d).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
    });
---

<BaseLayout>
    <section class="px-5">
        <div
            class="grid lg:grid-cols-2 gap-6 items-center container mx-auto pt-30"
        >
            <header class="mb-12 order-2 lg:order-1">
                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mb-4">
                    {
                        data.tags.map((tag: string) => (
                            <span class="text-sm text-primary/70 font-medium">
                                #{tag}
                            </span>
                        ))
                    }
                </div>

                <!-- Title -->
                <h1
                    class="text-3xl sm:text-4xl lg:text-5xl font-bold text-base-content leading-tight mb-6"
                >
                    {data.title}
                </h1>

                <!-- Excerpt -->
                <p class="text-xl text-base-content/60 leading-relaxed mb-8">
                    {data.excerpt}
                </p>

                <!-- Author + meta row -->
                <div
                    class="flex items-center gap-4 py-6 border-y border-base-300"
                >
                    <img
                        src={data.authorImage}
                        alt={data.author}
                        class="w-12 h-12 rounded-full object-cover bg-base-300"
                        onerror="this.src='https://placehold.co/48x48/1a1a1a/10b981?text=A'"
                    />
                    <div>
                        <p class="font-semibold text-base-content">
                            {data.author}
                        </p>
                        <p class="text-sm text-base-content/50">
                            {data.authorRole}
                        </p>
                    </div>
                    <div
                        class="ml-auto flex items-center gap-4 text-sm text-base-content/50"
                    >
                        <span>{formattedDate}</span>
                        <span class="w-1 h-1 rounded-full bg-base-content/30"
                        ></span>
                        <span>{data.readingTime} min read</span>
                    </div>
                </div>
            </header>

            <!-- Cover image -->
            <div
                class="rounded-2xl overflow-hidden mb-12 border border-base-300 order-1 lg:order-2"
            >
                <img
                    src={data.coverImage}
                    alt={data.title}
                    class="w-full h-auto block"
                    onerror={`this.src='https://placehold.co/1200x630/1a1a1a/10b981?text=' + encodeURIComponent('${data.title}')`}
                />
            </div>
        </div>
    </section>

    <main class="max-w-4xl mx-auto px-5 py-10">
        <!-- Markdown body -->
        <article
            class="prose prose-lg max-w-none
                       prose-headings:text-base-content
                       prose-headings:font-bold
                       prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
                       prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                       prose-p:text-base-content/70
                       prose-p:leading-relaxed
                       prose-strong:text-base-content
                       prose-a:text-primary prose-a:no-underline hover:prose-a:underline
                       prose-code:text-primary prose-code:bg-base-200 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
                       prose-pre:bg-base-200 prose-pre:border prose-pre:border-base-300 prose-pre:rounded-xl
                       prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:bg-base-200 prose-blockquote:rounded-r-xl prose-blockquote:py-1 prose-blockquote:not-italic
                       prose-blockquote:text-base-content/70
                       prose-li:text-base-content/70
                       prose-ul:my-4
                       prose-ol:my-4
                       prose-hr:border-base-300
                       prose-img:rounded-xl prose-img:border prose-img:border-base-300"
        >
            <Content />
        </article>

        <!-- ── Prev / Next navigation ─────────────────────────── -->
        <nav
            class="mt-16 pt-8 border-t border-base-300 grid grid-cols-1 sm:grid-cols-2 gap-4"
            aria-label="Post navigation"
        >
            <!-- Previous post (older) -->
            {
                prevPost ? (
                    <a
                        href={`/blog/${prevPost.data.slug}`}
                        class="group flex flex-col gap-2 rounded-2xl border border-base-300 hover:border-primary/50 bg-base-100 hover:bg-base-200/50 p-5 transition-all duration-300"
                    >
                        <span class="flex items-center gap-2 text-xs font-medium text-base-content/40 uppercase tracking-wider group-hover:text-primary transition-colors duration-200">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-3.5 h-3.5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 19l-7-7 7-7"
                                />
                            </svg>
                            Previous Post
                        </span>
                        <span class="text-sm font-semibold text-base-content group-hover:text-primary transition-colors duration-200 line-clamp-2 leading-snug">
                            {prevPost.data.title}
                        </span>
                        <span class="text-xs text-base-content/40 mt-auto">
                            {shortDate(prevPost.data.publishedAt)}
                        </span>
                    </a>
                ) : (
                    <div />
                )
            }

            <!-- Next post (newer) -->
            {
                nextPost ? (
                    <a
                        href={`/blog/${nextPost.data.slug}`}
                        class="group flex flex-col gap-2 rounded-2xl border border-base-300 hover:border-primary/50 bg-base-100 hover:bg-base-200/50 p-5 transition-all duration-300 sm:text-right sm:items-end"
                    >
                        <span class="flex items-center gap-2 text-xs font-medium text-base-content/40 uppercase tracking-wider group-hover:text-primary transition-colors duration-200 sm:flex-row-reverse">
                            Next Post
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-3.5 h-3.5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </span>
                        <span class="text-sm font-semibold text-base-content group-hover:text-primary transition-colors duration-200 line-clamp-2 leading-snug">
                            {nextPost.data.title}
                        </span>
                        <span class="text-xs text-base-content/40 mt-auto">
                            {shortDate(nextPost.data.publishedAt)}
                        </span>
                    </a>
                ) : (
                    <div />
                )
            }
        </nav>

        <!-- Back to all posts -->
        <div class="mt-6">
            <a href="/" class="btn btn-outline btn-primary btn-sm gap-2">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
                </svg>
                Back to All Posts
            </a>
        </div>
    </main>

    <section class="px-5 pt-12 pb-20">
        <h2
            class="text-3xl md:text-4xl lg:text-5xl font-bold mt-4 mb-6 text-base-content container mx-auto"
        >
            Related News
        </h2>
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 container mx-auto mt-8"
        >
            {
                categoryPosts.map((relatedPost: BlogPost, i: number) => (
                    <BlogCard post={relatedPost} index={i} />
                ))
            }
        </div>
    </section>
</BaseLayout>
